# ============================================
# ARCHIVO DE EJEMPLO - NO EDITAR ESTE ARCHIVO
# ============================================
# Copia este archivo como .env y completa con tus valores reales
# 
# Comando: cp .env.example .env
# 

# Configuración de Seguridad
SECRET_KEY=tu-secret-key-super-segura-aqui-generala-con-django

# Modo de Depuración (SIEMPRE False en producción)
DEBUG=True

# Hosts Permitidos (separados por coma, sin espacios)
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS para frontend React local
CORS_ENABLED=True
API_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Base de Datos PostgreSQL
DB_NAME=colegio_db
DB_USER=colegio_user
DB_PASSWORD=tu-password-seguro-aqui
DB_HOST=localhost
DB_PORT=5432

# Email Configuration (opcional)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=tu-email@gmail.com
# EMAIL_HOST_PASSWORD=tu-app-password

# Redis para Producción (con Channels)
# REDIS_URL=redis://localhost:6379

# ============================================
# GENERAR SECRET_KEY:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# ============================================
