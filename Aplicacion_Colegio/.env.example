# ============================================
# ARCHIVO DE EJEMPLO - NO EDITAR ESTE ARCHIVO
# ============================================
# Copia este archivo como .env y completa con tus valores reales
# 
# Comando: cp .env.example .env
# 

# Configuración de Seguridad
SECRET_KEY=tu-secret-key-super-segura-aqui-generala-con-django

# Modo de Depuración (SIEMPRE False en producción)
DEBUG=True

# Hosts Permitidos (separados por coma, sin espacios)
ALLOWED_HOSTS=localhost,127.0.0.1

# Localización
LANGUAGE_CODE=es-cl
TIME_ZONE=America/Santiago

# Base de Datos
# Opciones: sqlite (desarrollo), postgresql (producci\u00f3n), mssql (SQL Server)
DB_ENGINE=sqlite

# PostgreSQL Configuration (solo si DB_ENGINE=postgresql)
DB_NAME=colegio_db
DB_USER=colegio_user
DB_PASSWORD=tu-password-seguro-aqui
DB_HOST=localhost
DB_PORT=5432

# Alternativa: DATABASE_URL (formato: postgresql://user:pass@host:port/dbname)
# Usar esto en plataformas como Heroku, Railway, Render
# DATABASE_URL=postgresql://colegio_user:password@localhost:5432/colegio_db

# Redis para Channel Layers en Producci\u00f3n
# Dejar vac\u00edo para usar InMemoryChannelLayer en desarrollo
REDIS_URL=

# Email Configuration (SMTP)
# Dejar EMAIL_HOST vac\u00edo para usar console backend en desarrollo
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_TIMEOUT=10
DEFAULT_FROM_EMAIL=noreply@colegio.cl
SERVER_EMAIL=root@localhost

# Proveedores SMTP recomendados:
# - SendGrid: smtp.sendgrid.net (100 emails/d\u00eda gratis)
# - Gmail: smtp.gmail.com (requiere App Password)
# - AWS SES: email-smtp.us-east-1.amazonaws.com
# - Mailgun: smtp.mailgun.org

# hCaptcha Configuration (obtener claves en https://www.hcaptcha.com/)
# IMPORTANTE: Nunca commitear las claves reales en el repositorio
HCAPTCHA_SITEKEY=your-hcaptcha-sitekey-here
HCAPTCHA_SECRET=your-hcaptcha-secret-here
HCAPTCHA_ENABLED=False

# Webhook de pagos
# Usar al menos una de estas opciones para validar eventos entrantes
PAYMENT_WEBHOOK_TOKEN=
PAYMENT_WEBHOOK_SECRET=

# ============================================
# GENERAR SECRET_KEY:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# ============================================
